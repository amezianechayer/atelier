{
  "name": "atelier",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "biome check . && turbo run typecheck test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "db:generate": "pnpm --filter @atelier/db db:generate",
    "db:migrate": "pnpm --filter @atelier/db db:migrate",
    "db:reset": "pnpm --filter @atelier/db db:reset"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "turbo": "2.10.4",
    "typescript": "5.9.3"
  }
}
