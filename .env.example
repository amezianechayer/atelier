# --- Base de données (docker/compose.dev.yml fournit ces valeurs en dev) ---
DATABASE_URL=postgres://atelier:atelier@localhost:5432/atelier

# --- Stockage objet (MinIO en dev) ---
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=atelier
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- Auth (Phase 1) ---
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Console Google Cloud > OAuth 2.0 (origine http://localhost:3000,
# redirection http://localhost:3000/api/auth/callback/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Emails produit + magic links (Mailpit en dev, Resend en prod) ---
RESEND_API_KEY=
EMAIL_FROM=Atelier <atelier@localhost>
MAILPIT_URL=http://localhost:8025

# --- LLM (Phase 2) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Inngest (vides en dev : le dev server ne signe pas) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Telegram (Phase 6) ---
TELEGRAM_BOT_TOKEN=

# --- Stripe (Phase 8, clés de test) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Coffre à secrets : 32 octets encodés base64 (AES-256-GCM) ---
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRETS_MASTER_KEY=

# --- Sandbox Builder (Phase 4) ---
SANDBOX_IMAGE=atelier/sandbox:dev

# --- Budgets ---
DEFAULT_NIGHT_LIMIT_USD=1.00

# --- Observabilité (optionnel) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
